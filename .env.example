# Turso (libSQL) database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Comma-separated list of emails allowed to sign in
ALLOWED_EMAILS=you@example.com

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM=Fieldwork <noreply@yourdomain.com>
EMAIL_REPLY_TO=Your Name <you@yourdomain.com>

# Base URL used to build magic links (no trailing slash)
APP_URL=https://your-app.example.com

# Anthropic key for LLM enrichment
ANTHROPIC_API_KEY=

# Search provider for changelog discovery
# Supported values: brave
SEARCH_PROVIDER=brave

# Brave Web Search API key (https://api.search.brave.com)
BRAVE_SEARCH_API_KEY=

# Minimum delay between Brave search calls in milliseconds (avoid rate limits)
CHANGELOG_SEARCH_DELAY_MS=1100
